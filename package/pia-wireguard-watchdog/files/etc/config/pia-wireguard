config service 'main'
	option enabled '1'
	option interface 'wg0_pia'
	option region 'swiss'
	option check_interval '60'
	option handshake_max_age '180'
	option restore_timeout '30'
	option restart_delay '5'
	option ping_timeout '3'
	option reconfigure_min_interval '900'
	option egress_check_enabled '1'
	option egress_check_url 'https://api.ipify.org'
	option status_file '/var/run/pia-wireguard/status'
	option bootstrap_network 'lan'
	option bootstrap_interface ''
	option bootstrap_gateway ''
	option bootstrap_dns ''
	option mtu '1250'
	option allowed_ips '0.0.0.0/0'
	option persistent_keepalive '25'
	option serverlist_url 'https://serverlist.piaservers.net/vpninfo/servers/v6'
	option token_url 'https://www.privateinternetaccess.com/api/client/v2/token'
	option add_key_port '1337'
